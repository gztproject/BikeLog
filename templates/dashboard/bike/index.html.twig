{% extends 'dashboard/layout.html.twig' %}

{% block body_id 'bike_index' %}

{% block main %}
{% set visibleBikeCount = bikes|length %}
{% set totalOdometer = 0 %}
{% set totalDistance = 0 %}
{% set totalMaintenanceCost = 0 %}
{% set totalFuelCost = 0 %}

{% for bike in bikes %}
    {% set totalOdometer = totalOdometer + bike.odometer %}
    {% set totalDistance = totalDistance + bike.totalDistance %}
    {% set totalMaintenanceCost = totalMaintenanceCost + bike.totalMaintenanceCosts %}
    {% set totalFuelCost = totalFuelCost + bike.totalFuelPrice %}
{% endfor %}

<section class="page-shell dashboard-page dashboard-page--bikes">
    <div class="dashboard-page__header">
        <div>
            <span class="dashboard-page__eyebrow">{{ 'label.workshopProfile'|trans }}</span>
            <h1 class="page-shell__title">{{ 'title.myBikes'|trans }}</h1>
            <p class="dashboard-page__intro">{{ 'body.bikeIndex.summary'|trans }}</p>
        </div>
        <div class="dashboard-page__header-actions">
            <a href="{{ path('bike_new') }}" class="btn btn-success dashboard-page__primary-action">
                <i class="fa fa-plus" aria-hidden="true"></i> {{ 'action.add.bike'|trans }}
            </a>
            <a href="{{ path('dashboard_index') }}" class="btn btn-outline-secondary">
                <i class="fa fa-tachometer-alt" aria-hidden="true"></i> {{ 'menu.home'|trans }}
            </a>
        </div>
    </div>

    <div class="dashboard-stat-strip">
        <article class="dashboard-stat-card">
            <span class="dashboard-stat-card__label">{{ 'label.inventoryCount'|trans }}</span>
            <strong class="dashboard-stat-card__value">{{ visibleBikeCount|number_format }}</strong>
            <span class="dashboard-stat-card__meta">{{ 'label.visibleOnThisPage'|trans }}</span>
        </article>
        <article class="dashboard-stat-card">
            <span class="dashboard-stat-card__label">{{ 'label.totalOdometer'|trans }}</span>
            <strong class="dashboard-stat-card__value">{{ totalOdometer|number_format }}</strong>
            <span class="dashboard-stat-card__meta">km</span>
        </article>
        <article class="dashboard-stat-card">
            <span class="dashboard-stat-card__label">{{ 'label.totalDistance'|trans }}</span>
            <strong class="dashboard-stat-card__value">{{ totalDistance|number_format }}</strong>
            <span class="dashboard-stat-card__meta">km</span>
        </article>
        <article class="dashboard-stat-card">
            <span class="dashboard-stat-card__label">{{ 'label.totalMaintenanceCosts'|trans }}</span>
            <strong class="dashboard-stat-card__value">{{ totalMaintenanceCost|number_format(2) }}</strong>
            <span class="dashboard-stat-card__meta">EUR</span>
        </article>
        <article class="dashboard-stat-card">
            <span class="dashboard-stat-card__label">{{ 'label.totalFuelCosts'|trans }}</span>
            <strong class="dashboard-stat-card__value">{{ totalFuelCost|number_format(2) }}</strong>
            <span class="dashboard-stat-card__meta">EUR</span>
        </article>
    </div>

    <div class="inventory-panel">
        <div class="inventory-panel__header">
            <div>
                <h2 class="inventory-panel__title">{{ 'label.bikeOverview'|trans }}</h2>
                <p class="inventory-panel__subtitle">{{ 'body.bikeIndex.inventory'|trans }}</p>
            </div>
            {% if visibleBikeCount > 0 %}
                <span class="inventory-panel__badge">{{ visibleBikeCount|number_format }} {{ 'label.units.bikes'|trans }}</span>
            {% endif %}
        </div>

        {{ include('dashboard/bike/_table.html.twig', {
            bikes: bikes
        }, with_context = false) }}
    </div>

    <div class="pagination-shell">
        {{ knp_pagination_render(bikes) }}
    </div>
</section>
{% endblock %}

{% block sidebar %}
    {{ parent() }}

    <section class="sidebar-card">
        <h2 class="sidebar-card__title">{{ 'label.workshopActions'|trans }}</h2>
        <p class="sidebar-card__text">{{ 'body.bikeIndex.sidebar'|trans }}</p>
        <a href="{{ path('bike_new') }}" class="btn btn-success btn-block">
            <i class="fa fa-plus" aria-hidden="true"></i> {{ 'action.add.bike'|trans }}
        </a>
        <a href="{{ path('refueling_new') }}" class="btn btn-outline-secondary btn-block">
            <i class="fa fa-gas-pump" aria-hidden="true"></i> {{ 'action.add.refueling'|trans }}
        </a>
    </section>
{% endblock %}
