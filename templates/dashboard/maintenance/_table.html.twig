<div class="table-responsive-xl {% if scrollable|default(false) %}inventory-panel__table-scroll{% else %}inventory-panel__table-shell{% endif %}">
	<table class="table table-hover table-bordered workshop-table maintenance-table">
		<thead class="thead-dark">
			<tr>
				<th scope="col">{{ 'label.date'|trans }}</th>
				<th scope="col">{{ 'title.workshop'|trans }}</th>
				<th scope="col">{{ 'label.odometer'|trans }}</th>
				<th scope="col">{{ 'label.spentTime'|trans }}</th>
				<th scope="col">{{ 'label.task'|trans }}</th>
				<th scope="col">{{ 'label.cost'|trans }}</th>
				<th scope="col">{{ 'label.comment'|trans }}</th>
			</tr>
		</thead>
		<tbody>
			{% for m in maintenances %}
			{% set midx = loop.index0 %}
            {% set primaryTask = m.maintenanceTasks|first %}
			<tr class="maintenance-main collapsed" data-toggle="collapse"
				{% if m.maintenanceTasks.count > 1%}
				data-target=".maintenance-{{ midx }}" aria-expanded="false"
				{% endif %}>
				<td>
                    <div class="workshop-table__stack">
                        <strong>{{ m.dateString }}</strong>
                        {% if m.maintenanceTasks.count > 1 %}
                            <small class="text-muted">{{ m.maintenanceTasks.count|number_format }} {{ 'label.trackedTasks'|trans }}</small>
                        {% endif %}
                    </div>
                </td>
				<td>{{ m.workshop.name }}</td>
				<td>{{ m.odometer|number_format }} km</td>
				<td>{{ m.spentTime|number_format(1) }} h</td>
				<td>
                    <div class="workshop-table__stack">
                        <strong>{{ m.description(40) }}</strong>
                        {% if primaryTask %}
                            <small class="text-muted">
                                {{ primaryTask.task.name }}
                                {% if m.maintenanceTasks.count > 1 %}
                                    <i id="caret-{{ midx }}" class="arrow fa fa-caret-down" aria-hidden="true"></i>
                                {% endif %}
                            </small>
                        {% endif %}
                    </div>
                </td>
				<td>{{ m.totalCost|number_format(2) }} €</td>
				<td>{{ m.comment }}</td>
			</tr>

			{% for mt in m.maintenanceTasks %}
			<tr class="collapse maintenance-{{ midx }} workshop-table__subrow"
				id="task-{{ midx }}-{{ loop.index0 }}">
				<td></td>
				<td></td>
				<td></td>
				<td></td>
				<td>
                    <div class="workshop-table__stack">
                        <strong>{{ mt.task.name }}</strong>
                        <small class="text-muted">{{ mt.task.description }}</small>
                    </div>
                </td>
				<td>{{ mt.cost|number_format(2) }} €</td>
				<td>{{ mt.comment }}</td>
			</tr>
			{% endfor %}
			{% else %}
			<tr class="table-warning">
				<td colspan="7" align="center">{{ 'label.noneFound.maintenances'|trans }}</td>
			</tr>
			{% endfor %}
		</tbody>
	</table>
</div>
