{
	"type" : "project",
	"license" : "MIT",
	"require" : {
		"php": "^8.2",
		"ext-ctype": "*",
		"ext-iconv": "*",
		"doctrine/annotations": "^2.0",
		"doctrine/doctrine-bundle": "~2.6",
		"doctrine/doctrine-migrations-bundle": "~3.2",
		"doctrine/orm": "~2.12",
		"knplabs/knp-paginator-bundle": "^5.8 || ^6.0",
		"moment/moment": "~2.29",
		"ramsey/uuid": "~4.3",
		"ramsey/uuid-doctrine": "~1.8",
		"shivas/versioning-bundle": "^4.0 || ^5.0",
		"symfony/console": "^7.0",
		"symfony/dependency-injection": "^7.0",
		"symfony/dotenv": "^7.0",
		"symfony/flex": "~2.2",
		"symfony/form": "^7.0",
		"symfony/framework-bundle": "^7.0",
		"symfony/http-foundation": "^7.0",
		"symfony/intl": "^7.0",
		"symfony/mailer": "^7.0",
		"symfony/mime": "^7.0",
		"symfony/monolog-bundle": "~3.8",
		"symfony/runtime": "^7.0",
		"symfony/security-bundle": "^7.0",
		"symfony/security-core": "^7.0",
		"symfony/security-csrf": "^7.0",
		"symfony/security-http": "^7.0",
		"symfony/translation": "^7.0",
		"symfony/twig-bundle": "^7.0",
		"symfony/validator": "^7.0",
		"symfony/webpack-encore-bundle": "^1.14 || ^2.0",
		"symfony/yaml": "^7.0",
		"twig/extra-bundle": "~3.4",
		"twig/intl-extra": "~3.4",
		"twig/twig": "~3.4"
	},
	"config" : {
		"preferred-install" : {
			"*" : "dist"
		},
		"platform" : {
			"php" : "8.2.0"
		},
		"sort-packages" : true,
		"allow-plugins" : {
			"composer/installers": true,
			"oomphinc/composer-installers-extender": true,
			"symfony/flex": true,
			"symfony/runtime": true
		}
	},
	"autoload" : {
		"psr-4" : {
			"App\\" : "src/"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"App\\Tests\\" : "tests/"
		}
	},
	"replace" : {
		"paragonie/random_compat" : "2.*",
		"symfony/polyfill-ctype" : "*",
		"symfony/polyfill-iconv" : "*"
	},
	"conflict" : {
		"symfony/symfony" : "*"
	},
	"extra" : {
		"symfony" : {
			"allow-contrib" : false,
			"require" : "^7.0"
		}
	},
	"name" : "gztproject/bike-log",
	"require-dev" : {
		"doctrine/doctrine-fixtures-bundle" : "~3.4",
		"phpunit/phpunit" : "~9.5",
		"symfony/browser-kit" : "^7.0",
		"symfony/css-selector" : "^7.0",
		"symfony/debug-bundle" : "^7.0",
		"symfony/maker-bundle" : "~1.43",
		"symfony/phpunit-bridge" : "^7.0",
		"symfony/stopwatch" : "^7.0",
		"symfony/web-profiler-bundle" : "^7.0"
	},
	"support" : {
		"email" : "gasper@gzt.si",
		"issues" : "https://github.com/gztproject/BikeLog/issues",
		"wiki" : "https://github.com/gztproject/BikeLog/wiki",
		"source" : "https://github.com/gztproject/BikeLog"
	},
	"description" : "A web based motorcycle maintenance logging software",
	"homepage" : "https://github.com/gztproject/BikeLog",
	"authors" : [{
			"name" : "GaŠper Doljak",
			"email" : "gasper@gzt.si",
			"homepage" : "https://www.gzt.si",
			"role" : "Author"
		}
	],
	"minimum-stability" : "stable"
}
